{
  "extends": ["@twinscom/stylelint-config"],

  "rules": {
    "max-nesting-depth": 1,
    "selector-max-attribute": 3,
    "selector-max-class": 1,
    "selector-max-pseudo-class": 4,
    "selector-max-specificity": "0,4,0",
    "selector-max-universal": null,

    "scales/line-heights": [1.15, 1.4],
    "scales/space": [
      {
        "scale": [-1000, 0.1, 0.25, 0.35, 0.4, 0.45, 0.5, 0.75, 1, 2, 4],
        "units": ["rem"]
      }
    ],

    "defensive-css/require-at-layer": null,

    "property-layout-mappings": null,
    "unit-layout-mappings": null
  },

  "overrides": [
    {
      "files": [".storybook/fix.css"],

      "rules": {
        "selector-max-class": null,
        "declaration-no-important": null,
        "selector-no-qualifying-type": null,
        "property-layout-mappings": null,

        "defensive-css/require-flex-wrap": null
      }
    }
  ],

  "ignoreFiles": ["dist/holiday.css"]
}
